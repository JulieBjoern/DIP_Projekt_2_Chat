extends layout

block content
    main
        header
            h1 Specifik user
            a(href="/") Gå tilbage

        div
            p Her er den specifikke user:

            if user
                div.userBox
                    p Navn: #{user.username}
                    p Level: #{user.level}
                    p Oprettelsesdato: #{user.createdAt}
            else
                p Brugeren blev ikke fundet
