extends layout

block content
    main
        header
            h1 Opret bruger
            a(href="/") Gå tilbage

        div
            form(action="/users/adduser" method="POST")
                div
                    label(for="username") Brugernavn
                    input#username(type="text" name="username" required)

                div
                    label(for="password") Adgangskode
                    input#password(type="password" name="password" required)

                div
                    label(for="level") Level
                    select#level(name="level" required)
                        option(value="1") Level 1
                        option(value="2") Level 2
                        option(value="3") Level 3

                    

                button(type="submit") Opret bruger
