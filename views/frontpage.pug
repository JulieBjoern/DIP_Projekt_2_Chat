extends layout

block content
    div 
        p.loggedInAs Du er logget ind som: #{userName}
        p Her er en liste over chats:   

        table 
            if chats && chats.length
                each chat in chats
                    tr 
                        td
                            if isLoggedIn
                                a(href=`/chats/chat/${chat.id}/messages`, class='chat-link')= chat.name
                            else
                                span.chat-link.disabled-link= chat.name
                        td
                            if isLoggedIn && userLevel >= 2 && (userLevel === 3 || chat.ownerId === userId)
                                button.edit-btn(type="button", onclick=`editChat(${chat.id}, '${chat.name}')`) Rediger ✏️
                                button.delete-btn(type="button", onclick=`deleteChat(${chat.id})`) Slet 🗑️
            else
                tr
                    td Der er ikke oprettet nogle chats

        if isLoggedIn && userLevel > 1
            a(href="/chats/addchat")
                button(type="button") Opret chat💬
        else
            button(type="button" disabled) Opret chat💬

        if isLoggedIn
            a(href="/users")
                button(type="button") Se liste over brugere🤠🤠
        else
            button(type="button" disabled) Se liste over brugere🤠🤠

        if isLoggedIn
            form(action="/users/logout" method="post")
                button.logout(type="submit") Log ud
        else
            a(href="/users/login")
                button.login(type="button") Log ind
            a(href="/users/adduser")
                button(type="button") Opret bruger🤠

    script. 
        async function deleteChat(chatId) {
            const response = await fetch(`/chats/${chatId}`, {
                method: "DELETE"
            })
            
            if (response.ok) {
                location.reload()
            }
        }

        async function editChat(chatId, currentName) {
            const newName = prompt("Rediger chat-navn:", currentName)
            
            if (newName === null || newName.trim() === "") {
                return
            }
            
            const response = await fetch(`/chats/${chatId}`, {
                method: "PUT",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({ name: newName.trim() })
            })
            
            if (response.ok) {
                location.reload()
            }
        }
