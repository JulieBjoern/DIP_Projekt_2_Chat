extends layout

block content
    div 
        p.loggedInAs Du er logget ind som: #{userName}
        p Her er en liste over chats:   

        table 
            if chats && chats.length
                each chat in chats
                    tr 
                        td
                            a(href=`/chats/chat/${chat.id}/messages`, class='chat-link')= chat.name
            else
                tr
                    td Der er ikke oprettet nogle chats

        a(href="/chats/addchat")
            button(type="button") Opret chat

        a(href="/users/adduser")
            button(type="button") Opret bruger

        a(href="/users")
            button(type="button") Se liste over brugere

        button.logout(type="button") Log ud


